##############################################
# APLICAÇÃO
##############################################
APP_NAME="Impar Enquetes"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# URL do front-end (usada nos links dos e-mails, ex: reset de senha)
FRONTEND_URL=http://localhost:5173

##############################################
# BANCO DE DADOS
##############################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=impar_enquetes
DB_USERNAME=root
DB_PASSWORD=

##############################################
# FILA E BROADCASTING
##############################################
# Fila em 'database' guarda os jobs (e-mails) na tabela `jobs`.
QUEUE_CONNECTION=database

# Broadcasting via Reverb (WebSocket first-party do Laravel).
BROADCAST_CONNECTION=reverb

##############################################
# REVERB (WebSocket)
##############################################
# SERVER_*: onde o processo do Reverb escuta DENTRO da máquina.
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Credenciais do "app" Reverb (geradas por `php artisan install:broadcasting`).
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# HOST/PORT/SCHEME: endereço PÚBLICO que o navegador usa para conectar.
# Em dev: localhost:8080/http. Em produção: seu-dominio/443/https (via proxy Nginx).
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

##############################################
# E-MAIL (Mailtrap para desenvolvimento)
##############################################
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="nao-responda@imparenquetes.com"
MAIL_FROM_NAME="${APP_NAME}"
