# URL base da API Laravel (inclui o sufixo /api)
VITE_API_URL=http://127.0.0.1:8000/api

# --- Reverb / WebSocket ---
# A KEY é a mesma REVERB_APP_KEY definida no .env do backend.
VITE_REVERB_APP_KEY=

# Endereço público do servidor WebSocket.
# Em dev: localhost / 8080 / http
# Em produção: seu-dominio-da-api / 443 / https
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
